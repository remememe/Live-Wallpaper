{
    "compilerOptions": {
      "target": "ES2020",
      "module": "nodenext",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "outDir": "dist",
      "rootDir": "src",
      "moduleResolution": "nodenext"
    },
    "include": ["src/**/*.ts"]
}